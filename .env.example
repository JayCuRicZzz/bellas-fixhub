# ============================================
# Bellas FixHub — Environment Variables Template
# Copy to .env.local (dev) or set on Netlify Dashboard
# ============================================

# --- MySQL Database (REQUIRED) ---
# Local: localhost / Production: PlanetScale host
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hotel_fix

# --- JWT Authentication (REQUIRED) ---
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-64-char-random-string

# --- LINE Messaging API (for notifications) ---
LINE_ACCESS_TOKEN=
LINE_TARGET_ID_MAINT=
LINE_TARGET_ID_IT=

# --- Image Uploads ---
# Dev: leave empty (uses public/uploads/)
# Production (Netlify): set R2_ACCOUNT_ID + R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY
# Cloudflare R2 — free 10GB, no egress fees
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bellas-fixhub
R2_DEV_DOMAIN=

# --- Netlify ---
URL=https://your-app.netlify.app
